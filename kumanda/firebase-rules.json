{
  "rules": {
    "kumanda": {
      ".read": true,
      ".write": true,
      ".indexOn": ["zaman", "token_created"],
      
      "token": {
        ".read": true,
        ".write": false,
        ".validate": false,
        "value": { ".type": "string" },
        "created": { ".type": "number" },
        "expires": { ".type": "number" },
        "user_agent": { ".type": "string" }
      },
      
      "komut": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['kod', 'token', 'token_created', 'zaman'])",
        "kod": { ".type": "string" },
        "token": { ".type": "string" },
        "token_created": { ".type": "number" },
        "zaman": { ".type": "number" }
      },
      
      "anons": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['metin', 'token', 'token_created'])",
        "metin": { ".type": "string" },
        "token": { ".type": "string" },
        "token_created": { ".type": "number" },
        "zaman": { ".type": "number" }
      },
      
      "ses": {
        ".read": true,
        ".write": true
      },
      
      "sarki": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['ad', 'token', 'token_created'])"
      },
      
      "zil_sec": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['tip', 'melodi', 'token', 'token_created'])"
      },
      
      "sarki_liste": {
        ".read": true,
        ".write": false
      },
      
      "zil_listesi": {
        ".read": true,
        ".write": false
      },
      
      "durum": {
        ".read": true,
        ".write": false
      },
      
      "sistem_durum": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['aktif', 'token', 'token_created'])"
      },
      
      "genel_ayar": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['token', 'token_created'])"
      },
      
      "sifre": {
        ".read": false,
        ".write": true,
        ".validate": "newData.hasChildren(['tip', 'hash', 'token', 'token_created'])"
      }
    },
    
    "ayarlar": {
      ".read": false,
      ".write": false
    },
    
    "logs": {
      ".read": false,
      ".write": false,
      "security": {
        ".read": false,
        ".write": false,
        ".indexOn": ["timestamp", "type"]
      },
      "access": {
        ".read": false,
        ".write": false
      }
    },
    
    ".read": false,
    ".write": false
  }
}
